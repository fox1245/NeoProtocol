{
  "protocol_version": "neoprotocol/0",
  "task": {
    "id": "FIXTURE_TASK_ID",
    "type": "cowork_review",
    "human_description": "Code-review the workspace document. Two leaves run in parallel (summarize + find_issues), a reducer aggregates into a markdown report. Designed for SPEC §17.8 multi-host fan-out — leaves get assigned to different Coworkers in the room."
  },
  "graph": {
    "channels": {
      "document":      { "reducer": "replace" },
      "summary":       { "reducer": "replace" },
      "issues":        { "reducer": "replace" },
      "report":        { "reducer": "replace" }
    },
    "nodes": [
      {
        "id": "summarize",
        "kind": "leaf",
        "runtime": "client",
        "reads":  ["document"],
        "writes": ["summary"],
        "implementation": {
          "model": "server_described",
          "task": "text-generation",
          "prompt_template": "Summarize the following code in 2-3 sentences. Focus on what it does, not how. No code, no markdown.\n\nCode:\n{document}\n\nSummary:",
          "model_options": [
            {
              "runtime_kind": "local_onnx",
              "model_id": "onnx-community/Llama-3.2-1B-Instruct",
              "size_mb": 700,
              "quantized": true,
              "device_pref": ["webgpu", "wasm"]
            },
            {
              "runtime_kind": "byok_api",
              "byok_provider": "openai",
              "model_id": "gpt-5.4-mini",
              "endpoint": "https://api.openai.com/v1/chat/completions"
            },
            {
              "runtime_kind": "byok_api",
              "byok_provider": "anthropic",
              "model_id": "claude-sonnet-4-6",
              "endpoint": "https://api.anthropic.com/v1/messages"
            }
          ]
        }
      },
      {
        "id": "find_issues",
        "kind": "leaf",
        "runtime": "client",
        "reads":  ["document"],
        "writes": ["issues"],
        "implementation": {
          "model": "server_described",
          "task": "text-generation",
          "prompt_template": "Review the following code for potential issues — missing error handling, edge cases, naming, documentation. List up to 4 concrete issues, each as a single bullet. If you see no issues, return one bullet saying \"no obvious issues\". No code blocks.\n\nCode:\n{document}\n\nIssues:",
          "model_options": [
            {
              "runtime_kind": "local_onnx",
              "model_id": "onnx-community/Llama-3.2-1B-Instruct",
              "size_mb": 700,
              "quantized": true,
              "device_pref": ["webgpu", "wasm"]
            },
            {
              "runtime_kind": "byok_api",
              "byok_provider": "openai",
              "model_id": "gpt-5.4-mini",
              "endpoint": "https://api.openai.com/v1/chat/completions"
            },
            {
              "runtime_kind": "byok_api",
              "byok_provider": "anthropic",
              "model_id": "claude-sonnet-4-6",
              "endpoint": "https://api.anthropic.com/v1/messages"
            }
          ]
        }
      },
      {
        "id": "aggregate",
        "kind": "reducer",
        "runtime": "client",
        "reads":  ["summary", "issues"],
        "writes": ["report"],
        "implementation": {
          "model": "executor_registered",
          "node_name": "neoprotocol.builtin.markdown_report",
          "input_schema":  { "type": "object" },
          "output_schema": { "type": "object", "properties": { "markdown": { "type": "string" } } }
        }
      }
    ],
    "edges": [
      { "from": "__start__",   "to": "summarize" },
      { "from": "__start__",   "to": "find_issues" },
      { "from": "summarize",   "to": "aggregate" },
      { "from": "find_issues", "to": "aggregate" },
      { "from": "aggregate",   "to": "__end__" }
    ]
  },
  "input_data_ref": "FIXTURE_DATA_REF",
  "data_locality": {
    "raw_input_visibility": "client_only",
    "returns_to_originator": ["report_markdown_length", "leaf_durations_ms"]
  },
  "fallback_estimate": {
    "if_declined_originator_will": "Run via OpenAI gpt-5.4-mini (BYOK)",
    "estimated_cost_usd": 0.003,
    "estimated_latency_ms": 6000
  }
}
